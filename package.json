{
  "name": "nightshift-047-opsledger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.21",
  "scripts": {
    "dev": "bun --hot server/index.ts",
    "build": "bunx tsc --noEmit && bunx vite build && mkdir -p dist && bun build server/index.ts --target bun --outfile dist/server.js",
    "start": "NODE_ENV=production bun dist/server.js",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.10",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
