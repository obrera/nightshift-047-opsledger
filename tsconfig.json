{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./client/src/*"]
    }
  },
  "include": ["client/src", "server", "vite.config.ts", "tailwind.config.ts"]
}
